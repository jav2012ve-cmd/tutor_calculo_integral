# Plantilla de configuración local (Streamlit Secrets).
#
# 1) Copia este archivo como:  .streamlit/secrets.toml
# 2) Rellena los valores entre comillas.
# 3) NO subas secrets.toml a Git ni pegues claves reales en GitHub (issues, commits, etc.).
#
# En Streamlit Cloud: Settings → Secrets (mismas variables, en el panel de la app).

# Cualquiera de estas tres (solo necesitas una):
GOOGLE_API_KEY = ""
# GEMINI_API_KEY = ""
# GOOGLE_GEMINI_API_KEY = ""

# Opcional: cuenta de participante (registro / login) y estadísticas en Supabase.
# En Streamlit Cloud: Settings → Secrets, formato TOML, Save y reinicia la app.
# En Supabase: Project Settings → API → Project URL y clave service_role (secreta).
# SUPABASE_URL = "https://TU-PROYECTO.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY = "eyJ..."
# También válido: SUPABASE_KEY con el mismo valor de service_role.
# O una sección anidada:
# [supabase]
# url = "https://TU-PROYECTO.supabase.co"
# service_role_key = "eyJ..."
